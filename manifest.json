{
  "manifest_version": 3,
  "name": "Grid Overlay for Volleyball Analysis",
  "description": "Interactive volleyball court grid overlay for video analysis",
  "version": "1.0",
  "icons": {
    "16": "icon128.png",
    "48": "icon128.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "https://tv.volleyballworld.com/*"],
      "js": [
        "perspective-transform.js",
        "node_modules/onnxruntime-web/dist/ort.all.min.js",
        "auto-detect.js",
        "grid.js",
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "models/*.onnx",
        "node_modules/onnxruntime-web/dist/*.wasm",
        "node_modules/onnxruntime-web/dist/*.mjs"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
